print("Key Checking...")

local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")

local system_domains = {
    "https://get-key.keysystem352.workers.dev/",
    "https://get-key.keysystem2352.workers.dev/",
    "https://get-key.keysystem3352.workers.dev/"
}

local key_links = {
    "https://lnbz.la/KUvc4vDL",
    "https://lnbz.la/A2cPtbL2",
    "https://lnbz.la/RWfp"
}

local system_domain = nil
local key_link = nil
local valid_key = false
local key_pass = 1529641694

--------------------------------------------------
-- 🌐 FIND WORKING DOMAIN
--------------------------------------------------
for i, url in ipairs(system_domains) do
    local success, result = pcall(function()
        return game:HttpGet(url .. "status")
    end)

    if success and result == "true" then
        system_domain = url
        key_link = key_links[i]
        break
    end
end

if not system_domain then
    warn("No working key system domain found")
    return
end

