---2nd lvl
game:GetService("RunService").RenderStepped:Connect(function()
if AntiHookFunction == true then
   task.spawn(function()
     pcall(function()
     local request = request or http_request or (syn and syn.request) or (fluxus and fluxus.request) or (getgenv and getgenv().request) or (http and http.request)
     local url = "https://"..gen_random_str(math.random(8,16))..".com"
     local fetchtype = math.random(1, 2)
     local res = nil
     if fetchtype == 1 then
        res = request({ Url = url, Method = "GET" })
     else
        res = game:HttpGet(url)
     end
     end)
   end)
end
end)
