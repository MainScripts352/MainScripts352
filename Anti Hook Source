local functions = {
  rconsoleprint,
  print,
  warn,
  error,
  setclipboard,
  writefile,
  appendfile,
  delfile,
  readfile,
  isfile,
  isfolder,
  listfiles,
  getcustomasset,
  rconsoleerr,
  rconsolewarn,
  makefolder
}
local EnableFunctions = false
for i, v in next, functions do
    local old
    old = hookfunction(v, function(...)
        if not EnableFunctions then
            local args = {...}
            for i, arg in next, args do
                if tostring(i):find("local") or tostring(arg):find("local") then
                    game.Players.LocalPlayer:Kick("Hook Function Detected!")
                    return nil
                end
            end
        end
        return old(...)
    end)
end
task.spawn(function()
task.wait(5)
EnableFunctions = true
end)
